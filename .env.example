# ==============================================================================
# Server Configuration
# ==============================================================================
PORT=8080
NODE_ENV=development
APP_ENV=local

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=info

# ==============================================================================
# APM Performance Monitoring
# ==============================================================================
NEW_RELIC_APP_NAME=nestjs-starter-app
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here

# ==============================================================================
# Security & Origins
# ==============================================================================
CORS_ORIGINS=http://localhost:3000
CSRF_ENABLED=false
CSRF_SECRET=your_csrf_secret_string_here

# ==============================================================================
# Documentation & Features
# ==============================================================================
SWAGGER_ENABLED=true
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# Database & Cache Infrastructure
# ==============================================================================
REDIS_URL=redis://localhost:6379
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# ==============================================================================
# SMTP Mail Delivery Configuration
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password_here
MAIL_FROM=no-reply@example.com

# ==============================================================================
# Authentication & Security Tokens (JWT)
# ==============================================================================
COOKIE_AUTH=false
JWT_ACCESS_SECRET=your_jwt_access_secret_hex_here
JWT_ACCESS_TTL=1h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_hex_here
JWT_REFRESH_TTL=7d

# ==============================================================================
# Cloud Storage Infrastructure (AWS S3)
# ==============================================================================
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name